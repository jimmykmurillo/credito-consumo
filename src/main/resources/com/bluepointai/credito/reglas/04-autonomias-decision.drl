package com.bluepointai.credito.reglas;

import com.bluepointai.credito.modelo.Solicitante;
import com.bluepointai.credito.modelo.Solicitud;
import com.bluepointai.credito.modelo.ResultadoEvaluacion;

rule "Calcular ratios de la solicitud"
  salience 200
  no-loop true
  when
    $s : Solicitante(ingresoMensualNeto > 0)
    $sol : Solicitud()
    $r : ResultadoEvaluacion()
  then
    $sol.setRelacionCuotaIngreso($sol.getCuotaMensual() / $s.getIngresoMensualNeto());
    $sol.setRelacionDeudaIngreso($sol.getDeudaActualTotal() / $s.getIngresoMensualNeto());
    update($sol);
end

rule "Rechazo - Endeudamiento global excesivo"
  salience 85
  no-loop true
  when
    $sol : Solicitud(relacionDeudaIngreso >= 6.0)
    $r : ResultadoEvaluacion(decision == null)
  then
    $r.setDecision("RECHAZADO");
    $r.addMotivo("Endeudamiento total excede 6 veces el ingreso mensual. Ratio: " +
                 String.format("%.2f", $sol.getRelacionDeudaIngreso()) + "x");
    $r.setRequiereRevisionHumana(false);
    update($r);
end

rule "Alerta - Endeudamiento elevado"
  salience 75
  no-loop true
  when
    $sol : Solicitud(relacionDeudaIngreso >= 4.0, relacionDeudaIngreso < 6.0)
    $r : ResultadoEvaluacion(decision == null)
  then
    $r.setRequiereRevisionHumana(true);
    $r.addDetalle("Alerta: endeudamiento " + String.format("%.1f", $sol.getRelacionDeudaIngreso()) + "x el ingreso.");
    update($r);
end

rule "Bono fidelidad"
  salience 5
  no-loop true
  when
    $s : Solicitante(antiguedadLaboral >= 60, tipoEmpleo == "DEPENDIENTE")
    $r : ResultadoEvaluacion(decision == null)
  then
    $r.agregarPuntosScore(5);
    $r.addDetalle("Bono fidelidad: más de 5 años en empleo estable → +5 puntos adicionales");
end

rule "Penalización - Muchos dependientes"
  salience 5
  no-loop true
  when
    $s : Solicitante(numeroDependientes >= 4)
    $sol : Solicitud(relacionCuotaIngreso >= 0.25)
    $r : ResultadoEvaluacion(decision == null)
  then
    $r.agregarPuntosScore(-5);
    $r.addDetalle("Penalización: " + $s.getNumeroDependientes() + " dependientes → -5 puntos");
end

rule "Consolidar score y tomar decision"
  salience -5
  no-loop true
  when
    $s : Solicitante()
    $sol : Solicitud()
    $r : ResultadoEvaluacion(decision == null)
  then
    int score = $r.getScoreTotal();
    double monto = $sol.getMontoSolicitado();

    if (score >= 75 && monto <= 5000) {
        $r.setDecision("APROBADO");
        $r.setNivelDecision("MOTOR_AUTOMATICO");
        $r.setRequiereRevisionHumana(false);
        $r.addDetalle("Score " + score + "/100 — $" + monto + " → Aprobación automática");
    } else if (score >= 80 && monto > 5000 && monto <= 15000) {
        $r.setDecision("APROBADO");
        $r.setNivelDecision("MOTOR_AUTOMATICO");
        $r.setRequiereRevisionHumana(false);
        $r.addDetalle("Score " + score + "/100 — $" + monto + " → Aprobación automática");
    } else if (score >= 75 && monto > 15000 && monto <= 50000) {
        $r.setDecision("REVISION_HUMANA");
        $r.setNivelDecision("COMITE_CREDITO");
        $r.setRequiereRevisionHumana(true);
        $r.addDetalle("Score " + score + "/100 — $" + monto + " → Requiere Comité de Crédito");
    } else if (score >= 60 && monto > 5000 && monto <= 15000) {
        $r.setDecision("REVISION_HUMANA");
        $r.setNivelDecision("OFICIAL_CREDITO");
        $r.setRequiereRevisionHumana(true);
        $r.addDetalle("Score " + score + "/100 — $" + monto + " → Requiere Oficial de Crédito");
    } else if (score >= 45) {
        $r.setDecision("REVISION_HUMANA");
        $r.setNivelDecision("OFICIAL_CREDITO");
        $r.setRequiereRevisionHumana(true);
        $r.addDetalle("Score " + score + "/100 — Zona gris");
    } else {
        $r.setDecision("RECHAZADO");
        $r.setNivelDecision("MOTOR_AUTOMATICO");
        $r.setRequiereRevisionHumana(false);
        $r.addMotivo("Score insuficiente: " + score + "/100. Mínimo: 45 puntos.");
    }
    update($r);
end