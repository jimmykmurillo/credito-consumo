package com.bluepointai.credito.reglas;

import com.bluepointai.credito.modelo.Solicitante;
import com.bluepointai.credito.modelo.Solicitud;
import com.bluepointai.credito.resultado.ResultadoEvaluacion;

// ============================================================
// TABLA DE DECISIÓN 4: Límites de autonomía por monto y score
// Define qué nivel decide: MOTOR, OFICIAL, COMITE
// ============================================================

rule "Autonomía - Aprobación automática zona verde alta"
  salience 10
  when
    $r : ResultadoEvaluacion(
      decision != "RECHAZADO",
      scoreTotal >= 75
    )
    $sol : Solicitud(montoSolicitado <= 5000)
  then
    $r.setDecision("APROBADO");
    $r.setNivelDecision("MOTOR_AUTOMATICO");
    $r.setRequiereRevisionHumana(false);
    $r.addDetalle("Score " + $r.getScoreTotal() + "/100 — Monto $" + $sol.getMontoSolicitado() + " → Aprobación automática");
    update($r);
end

rule "Autonomía - Aprobación automática monto medio"
  salience 10
  when
    $r : ResultadoEvaluacion(
      decision != "RECHAZADO",
      scoreTotal >= 80
    )
    $sol : Solicitud(montoSolicitado > 5000, montoSolicitado <= 15000)
  then
    $r.setDecision("APROBADO");
    $r.setNivelDecision("MOTOR_AUTOMATICO");
    $r.setRequiereRevisionHumana(false);
    $r.addDetalle("Score " + $r.getScoreTotal() + "/100 — Monto $" + $sol.getMontoSolicitado() + " → Aprobación automática");
    update($r);
end

rule "Autonomía - Oficial de crédito monto medio score bajo"
  salience 9
  when
    $r : ResultadoEvaluacion(
      decision != "RECHAZADO",
      scoreTotal >= 60, scoreTotal < 80
    )
    $sol : Solicitud(montoSolicitado > 5000, montoSolicitado <= 15000)
  then
    $r.setDecision("REVISION_HUMANA");
    $r.setNivelDecision("OFICIAL_CREDITO");
    $r.setRequiereRevisionHumana(true);
    $r.addDetalle("Score " + $r.getScoreTotal() + "/100 — Monto $" + $sol.getMontoSolicitado() + " → Requiere Oficial de Crédito");
    update($r);
end

rule "Autonomía - Comité monto alto score alto"
  salience 9
  when
    $r : ResultadoEvaluacion(
      decision != "RECHAZADO",
      scoreTotal >= 75
    )
    $sol : Solicitud(montoSolicitado > 15000, montoSolicitado <= 50000)
  then
    $r.setDecision("REVISION_HUMANA");
    $r.setNivelDecision("COMITE_CREDITO");
    $r.setRequiereRevisionHumana(true);
    $r.addDetalle("Score " + $r.getScoreTotal() + "/100 — Monto $" + $sol.getMontoSolicitado() + " → Requiere Comité de Crédito");
    update($r);
end

rule "Autonomía - Zona gris: score medio cualquier monto"
  salience 8
  when
    $r : ResultadoEvaluacion(
      decision != "RECHAZADO",
      decision != "APROBADO",
      decision != "REVISION_HUMANA",
      scoreTotal >= 45, scoreTotal < 60
    )
  then
    $r.setDecision("REVISION_HUMANA");
    $r.setNivelDecision("OFICIAL_CREDITO");
    $r.setRequiereRevisionHumana(true);
    $r.addDetalle("Score " + $r.getScoreTotal() + "/100 — Zona gris: requiere revisión humana");
    update($r);
end

rule "Rechazo - Score insuficiente (< 45)"
  salience 7
  when
    $r : ResultadoEvaluacion(
      decision != "RECHAZADO",
      scoreTotal < 45
    )
  then
    $r.setDecision("RECHAZADO");
    $r.setNivelDecision("MOTOR_AUTOMATICO");
    $r.setRequiereRevisionHumana(false);
    $r.addMotivo("Score total insuficiente: " + $r.getScoreTotal() + "/100. Mínimo requerido: 45 puntos.");
    update($r);
end

// ============================================================
// TABLA DE DECISIÓN 5: Deuda total vs ingreso (endeudamiento)
// Rechaza si el endeudamiento global es excesivo
// ============================================================

rule "Rechazo - Endeudamiento global excesivo (>= 6x ingreso mensual)"
  salience 85
  when
    $sol : Solicitud(relacionDeudaIngreso >= 6.0)
    $r : ResultadoEvaluacion(decision != "RECHAZADO")
  then
    $r.setDecision("RECHAZADO");
    $r.addMotivo("Endeudamiento total excede 6 veces el ingreso mensual. Ratio actual: " + 
                 String.format("%.2f", $sol.getRelacionDeudaIngreso()) + "x");
    $r.setRequiereRevisionHumana(false);
    update($r);
end

rule "Alerta - Endeudamiento elevado (4-6x ingreso) → zona gris"
  salience 75
  when
    $sol : Solicitud(relacionDeudaIngreso >= 4.0, relacionDeudaIngreso < 6.0)
    $r : ResultadoEvaluacion(decision != "RECHAZADO")
  then
    $r.setRequiereRevisionHumana(true);
    $r.addDetalle("Alerta: endeudamiento total " + String.format("%.1f", $sol.getRelacionDeudaIngreso()) + "x el ingreso mensual.");
    update($r);
end

// ============================================================
// REGLA GUIADA 1: Bono por fidelidad — cliente con historial en la entidad
// ============================================================

rule "Bono fidelidad - Solicitante mayor a 60 meses en relación laboral estable"
  when
    $s : Solicitante(antiguedadLaboral >= 60, tipoEmpleo == "DEPENDIENTE")
    $r : ResultadoEvaluacion(decision != "RECHAZADO")
  then
    $r.agregarPuntosScore(5);
    $r.addDetalle("Bono fidelidad: más de 5 años en empleo estable → +5 puntos adicionales");
end

// ============================================================
// REGLA GUIADA 2: Penalización por número de dependientes
// ============================================================

rule "Penalización - Muchos dependientes (>= 4)"
  when
    $s : Solicitante(numeroDependientes >= 4)
    $sol : Solicitud(relacionCuotaIngreso >= 0.25)
    $r : ResultadoEvaluacion(decision != "RECHAZADO")
  then
    $r.agregarPuntosScore(-5);
    $r.addDetalle("Penalización: " + $s.getNumeroDependientes() + " dependientes con cuota/ingreso elevada → -5 puntos");
end

// ============================================================
// REGLA GUIADA 3: Cálculo previo de ratios (must-fire early)
// ============================================================

rule "Calcular ratios de la solicitud"
  salience 200
  when
    $s : Solicitante(ingresoMensualNeto > 0)
    $sol : Solicitud()
    $r : ResultadoEvaluacion()
  then
    double cuota = $sol.getCuotaMensual();
    double ingreso = $s.getIngresoMensualNeto();
    double rci = cuota / ingreso;
    double rdi = $sol.getDeudaActualTotal() / ingreso;
    $sol.setRelacionCuotaIngreso(rci);
    $sol.setRelacionDeudaIngreso(rdi);
    update($sol);
end
